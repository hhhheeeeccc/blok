<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/isolation_title"
        android:textColor="@color/onBackground"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"
        android:layout_gravity="right"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/isolation_subtitle"
        android:textColor="@color/onSurfaceVariant"
        android:textSize="14sp"
        android:layout_marginBottom="16dp"
        android:layout_gravity="right"/>

    <EditText
        android:id="@+id/search_apps"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/search_hint"
        android:textColor="@color/onSurface"
        android:textColorHint="@color/onSurfaceVariant"
        android:background="@color/surfaceVariant"
        android:padding="12dp"
        android:layout_marginBottom="16dp"
        android:textAlignment="viewEnd"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_view_apps"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
